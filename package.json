{
  "name": "harness2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "h2": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run typecheck && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "node --no-warnings --import tsx --test",
    "typecheck": "npm run typecheck:core && npm run typecheck:ui",
    "typecheck:core": "tsc -p tsconfig.json --noEmit",
    "typecheck:ui": "tsc -p packages/ui-opentui/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.51",
    "ai": "^6.0.149",
    "diff": "^8.0.4",
    "execa": "^9.6.0",
    "smol-toml": "^1.6.1",
    "tsx": "^4.19.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
